[
  {
    "id": "encuentro",
    "title": "Orqo Patapi Tinkuy",
    "subtitle": "Un encuentro en la montaña",
    "icon": "🌊",
    "level": "Básico",
    "scenes": [
      { 
        "type": "text", 
        "q": "Alberto: ¡Allin p'unchay Don! Kunan p'unchayqa paramushan.", 
        "e": "¡Buen día! Hoy está lloviendo." 
      },
      { 
        "type": "question", 
        "title": "¿Imaynataj p'unchay?", 
        "text": "¿Cómo está el día?", 
        "options": ["Paramushan (Está lloviendo)", "Mana paramushanchu (No está lloviendo)"], 
        "correct": 0 
      },
      { 
        "type": "text", 
        "q": "Noqa Alberto kani. Orqo patapi kashani.", 
        "e": "Yo soy Alberto. Estoy en la montaña." 
      },
      { 
        "type": "question", 
        "title": "¿Pitaj orqo patapi kashan?", 
        "text": "¿Quién está en la montaña?", 
        "options": ["Alberto", "Jorge"], 
        "correct": 0 
      },
      { 
        "type": "text", 
        "q": "Alberto: Chaypi Maria kashan. Payqa warmiy. Payqa llakisqa kashan.", 
        "e": "Alberto: Allí está Maria. Ella es mi esposa. Ella está triste." 
      },
      { 
        "type": "question", 
        "title": "¿Imaynatá Maria kashan?", 
        "text": "¿Cómo se encuentra Maria?", 
        "options": ["Llakisqa", "Kusisqa"], 
        "correct": 0 
      },
      { 
        "type": "text", 
        "q": "Imaynalla Maria! ¿Walejllachu?", 
        "e": "¡Hola Maria! ¿Estás bien?" 
      },
      { 
        "type": "text", 
        "q": "Allillan kashani. Noqa kusikuni rejsisuspa.", 
        "e": "Estoy bien nomás. Yo me alegro de conocerte." 
      },
      { 
        "type": "text", 
        "q": "Ujllata alqon jamun. Mariaqa kusisqa kashan alqon jamusqanrayku.", 
        "e": "De pronto viene su perro. Maria está contenta porque viene su perro." 
      },
      { 
        "type": "question", 
        "title": "¿Imarayku María kusisqa kashan?", 
        "text": "¿Por qué María está contenta?", 
        "options": ["Intirayku", "Alqorayku"], 
        "correct": 1 
      },
      { 
        "type": "text", 
        "q": "Tinkunakama Alberto! Wasiyman rishani.", 
        "e": "¡Nos vemos Alberto! Me estoy yendo a mi casa." 
      }
    ]
  }
]